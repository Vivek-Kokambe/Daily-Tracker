generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Tracker {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  slug String @unique

  // Full TrackerData stored as JSON
  waterCount     Int
  waterGoal      Int
  waterHistory   Json

  calorieGoal    Int
  foodLog        Json
  calorieHistory Json

  habits          Json
  habitCompletion Json
  habitStreaks    Json

  bedtime              String
  wakeTime             String
  sleepHistory         Json
  sleepQualityHistory  Json

  lastActiveDate String

  achievements  Json
  dailyScores   Json
  moodHistory   Json

  hasCompletedOnboarding Boolean
  glassSize              Int

  dailyNotes           Json
  profile              Json?
  weeklyChallenge      Json?
  waterRemindersEnabled Boolean
  savedFoods           Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
